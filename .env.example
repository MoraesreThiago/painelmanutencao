# Aplicação
APP_NAME=SGM
APP_SUBTITLE=Sistema de Gestão de Manutenção
ENVIRONMENT=development
TIMEZONE=America/Sao_Paulo

# Django
BACKEND_SECRET_KEY=change-this-secret-key
BACKEND_PORT=8000
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
DJANGO_SESSION_AGE=28800
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

# Banco principal
POSTGRES_DB=maintenance_platform
POSTGRES_USER=maintenance_user
POSTGRES_PASSWORD=maintenance_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://maintenance_user:maintenance_pass@localhost:5432/maintenance_platform

# Seed inicial
DEFAULT_ADMIN_EMAIL=admin@maintenance.example.com
DEFAULT_ADMIN_PASSWORD=Admin@123

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5
